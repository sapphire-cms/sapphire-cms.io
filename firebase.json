{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    },
    {
      "source": "sapphire-functions",
      "codebase": "sapphire",
      "ignore": [
        "node_modules"
      ]
    }
  ],
  "hosting": [
    {
      "target": "main",
      "public": "dist/sapphire-cms.io/browser",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "cms",
      "public": "node_modules/@sapphire-cms/manager-ui/dist/sapphire-manager-ui/browser",
      "rewrites": [
        {
          "source": "/manager-ui/**",
          "destination": "/manager-ui/index.html"
        },
        {
          "source": "/rest/**",
          "function": {
            "functionId": "sapphire"
          }
        }
      ]
    }
  ],
  "emulators": {
    "functions": {
      "port": 5001
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  }
}
